  public void cargarArchivo(File archivo) {
    if (archivo != null) {
      String[] lines = loadStrings(archivo.getAbsolutePath());
      if (lines != null) {
        this.movimientosGuardados.clear();
        byte b;
        int i;
        String[] arrayOfString;
        for (i = (arrayOfString = lines).length, b = 0; b < i; ) {
          String line = arrayOfString[b];
          String[] valores = line.split(" ");
          ArrayList<Integer> movimientos = new ArrayList<>();
          byte b1;
          int j;
          String[] arrayOfString1;
          for (j = (arrayOfString1 = valores).length, b1 = 0; b1 < j; ) {
            String valor = arrayOfString1[b1];
            movimientos.add(Integer.valueOf(Integer.parseInt(valor)));
            b1++;
          } 
          this.movimientosGuardados.add(movimientos);
          b++;
        } 
        println("Posiciones guardadas importadas exitosamente.");
        this.stemBotMensaje = "P O S I C I O N E S    I M P O R T A D A S   E X I T O S A M E N T E";
      } else {
        println("No se encontrningarchivo de posiciones guardadas.");
        this.stemBotMensaje = "N O  S E  E N C O N T R O  N I N G U N   A R C H I V O";
      } 
    } else {
      println("No se selecciono ningun archivo para importar.");
      this.stemBotMensaje = "N O  S E   S E L E C C I O N O  N I N G Ú N   A R C H I V O";
    } 
  }
  
  public void resetearPosiciones() {
