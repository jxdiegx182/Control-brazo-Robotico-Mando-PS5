  public void controlEvent(ControlEvent theEvent) {
    if (theEvent.isFrom("portDropdown")) {
      int selection = PApplet.parseInt(theEvent.getValue());
      String selectedPort = this.portList[selection];
      println("Selected port: " + selectedPort);
      if (this.myPort != null)
        this.myPort.stop(); 
      this.myPort = new Serial(this, selectedPort, 9600);
    } else if (theEvent.isFrom("detenerMovimiento")) {
      detenerMovimiento();
    } 
  }
  
  public void guardarMovimientos() {
    ArrayList<Integer> movimientos = new ArrayList<>();
    for (int i = 0; i < 6; i++) {
      int barValue = (int)this.cp5.getController("servo_" + (i + 1)).getValue();
      movimientos.add(Integer.valueOf(barValue));
    } 
    this.movimientosGuardados.add(new ArrayList<>(movimientos));
    println("Movimiento guardado: " + movimientos);
    this.stemBotMensaje = "P  O  S  I  C  I  O  N    -    G  U  A  R  D  A  D  A  :   " + movimientos;
  }
  
  public void reproducirMovimientos() {
    if (!this.reproduciendo && !this.movimientosGuardados.isEmpty()) {
      this.reproduciendo = true;
      println("Reproduciendo movimientos!.");
      this.stemBotMensaje = "R  E  P  R  O  D  U  C  I  E  N  D  O    -    M  O  V  I  M  I  E  N  T  O  S !";
      
      
      Thread thread = new Thread(new Runnable() {
            public void run() {
              while (controlbrazo.this.reproduciendo) {
                int numMovimientos = controlbrazo.this.movimientosGuardados.size();
                int movimientoSiguiente = (controlbrazo.this.movimientoActual + 1) % numMovimientos;
                ArrayList<Integer> movimientosActuales = controlbrazo.this.movimientosGuardados.get(controlbrazo.this.movimientoActual);
                ArrayList<Integer> movimientosSiguientes = controlbrazo.this.movimientosGuardados.get(movimientoSiguiente);
                ArrayList<Integer> currentValues = new ArrayList<>();
                for (int i = 0; i < movimientosActuales.size(); i++)
                  currentValues.add(Integer.valueOf((int)controlbrazo.this.cp5.getController("servo_" + (i + 1)).getValue())); 
                int steps = 50;
                for (int step = 0; step <= steps; step++) {
                  for (int j = 0; j < movimientosActuales.size(); j++) {
                    ((Integer)movimientosActuales.get(j)).intValue();
                    int servoValueSiguiente = ((Integer)movimientosSiguientes.get(j)).intValue();
                    int currentValue = ((Integer)currentValues.get(j)).intValue();
                    int newValue = currentValue + (servoValueSiguiente - currentValue) * step / steps;
                    controlbrazo.this.cp5.getController("servo_" + (j + 1)).setValue(newValue);
                    if (controlbrazo.this.myPort != null)
                      controlbrazo.this.myPort.write(String.valueOf(j + 1) + " " + newValue + "\n"); 
                  } 
                  controlbrazo.this.delay(controlbrazo.this.velocidadReproduccion / steps);
                } 
                controlbrazo.this.movimientoActual = movimientoSiguiente;
              } 
            }
          });
      thread.start();
    } 
  }
  
  public void detenerMovimiento() {
    for (int i = 0; i < 6; i++) {
      int currentValue = (int)this.cp5.getController("servo_" + (i + 1)).getValue();
      this.cp5.getController("servo_" + (i + 1)).setValue(currentValue);
      if (this.myPort != null)
        this.myPort.write(String.valueOf(i + 1) + " " + currentValue + "\n"); 
    } 
    this.reproduciendo = false;
    println("Movimientos detenidos.");
    this.stemBotMensaje = "M  O  V  I  M  I  E  N  T  O  S    -    D  E  T  E  N  I  D  O  S !";
  }
  
