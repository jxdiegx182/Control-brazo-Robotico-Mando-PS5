  public void guardarArchivo(File archivo) {
    if (archivo != null) {
      String[] lines = new String[this.movimientosGuardados.size()];
      for (int i = 0; i < this.movimientosGuardados.size(); i++) {
        ArrayList<Integer> movimientos = this.movimientosGuardados.get(i);
        StringBuilder line = new StringBuilder();
        for (Integer movimiento : movimientos)
          line.append(movimiento).append(" "); 
        lines[i] = line.toString().trim();
      } 
      saveStrings(archivo.getAbsolutePath(), lines);
      println("Posiciones guardadas exportadas exitosamente.");
      this.stemBotMensaje = "P  O  S  I  C  I  O  N  E  S    -    E  X  P  O  R  T  A  D  A  S    -    E  X  I  T  O  S  A  M  E  N  T  E";
    } else {
      println("No se selecciono ningún archivo para exportar.");
      this.stemBotMensaje = "N O   S E   S E L E C C I O N O  N I N G Ú N   A R C H I V O";
    } 
  }
  
