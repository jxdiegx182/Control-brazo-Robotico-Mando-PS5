class Message {
    String text;
    
    int timestamp;
    
    Message(String text) {
      this.text = text;
      this.timestamp = controlbrazo.this.millis();
    }
    
    public void display(float x, float y) {
      int alpha = 255;
      int elapsedTime = controlbrazo.this.millis() - this.timestamp;
      if (elapsedTime < controlbrazo.this.fadeOutDuration)
        alpha = (int)controlbrazo.map(elapsedTime, 0.0F, controlbrazo.this.fadeOutDuration, 255.0F, 0.0F); 
      controlbrazo.this.fill(0, alpha);
      controlbrazo.this.textAlign(0);
      controlbrazo.this.text(this.text, x, y);
    }
    
    public boolean isExpired() {
      return (controlbrazo.this.millis() - this.timestamp > controlbrazo.this.fadeOutDuration);
    }
  }
  
